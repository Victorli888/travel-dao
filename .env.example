ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion integration token from https://www.notion.so/my-integrations
# The integration must be shared with your planner page
NOTION_API_KEY=your_notion_integration_token_here

# Exact name of the Notion page to save activities under
NOTION_PAGE_NAME=Travel Planner

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Google OAuth — from https://console.cloud.google.com/
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# Neon Postgres connection string — from console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname
